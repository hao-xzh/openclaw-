@echo off
setlocal EnableExtensions
chcp 65001 >nul 2>&1
title OpenClaw Installer

where powershell >nul 2>&1
if errorlevel 1 (
    echo.
    echo [ERROR] PowerShell was not found on this system.
    echo.
    pause
    exit /b 1
)

set "SELF_PATH=%~f0"
set "TEMP_PS1=%TEMP%\%~n0-%RANDOM%%RANDOM%.ps1"

powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -Command "$lines=Get-Content -LiteralPath $env:SELF_PATH | Where-Object { $_ -like '::PS1B64::*' }; if(-not $lines){ throw 'Embedded payload not found.' }; $base64=($lines -replace '^::PS1B64::', '') -join ''; [System.IO.File]::WriteAllBytes($env:TEMP_PS1, [Convert]::FromBase64String($base64))"
if errorlevel 1 (
    echo.
    echo [ERROR] Failed to prepare embedded PowerShell payload.
    echo.
    pause
    exit /b 1
)

powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File "%TEMP_PS1%" %*
set "EXIT_CODE=%ERRORLEVEL%"
del "%TEMP_PS1%" >nul 2>&1

echo.
if "%EXIT_CODE%"=="0" (
    echo [INFO] Installer finished successfully.
) else (
    echo [ERROR] Installer exited with code %%EXIT_CODE%%.
)
echo.
pause
exit /b %EXIT_CODE%

